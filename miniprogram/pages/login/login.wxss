.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1677ff 0%, #4096ff 40%, #f5f5f5 40%);
  padding-top: 80rpx;
}

.logo-area {
  padding: 40rpx 0 60rpx;
}

.tab-bar {
  display: flex;
  justify-content: center;
  gap: 0;
}

.tab-item {
  padding: 16rpx 56rpx;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.active {
  color: #ffffff;
  font-weight: 600;
  border-bottom-color: #ffffff;
}

.form-card {
  margin: 0 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.avatar-row {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #e8e8e8;
  margin-bottom: 12rpx;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999999;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.input-row:last-child {
  border-bottom: none;
}

.input-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.field-input::placeholder {
  color: #cccccc;
}

.error-msg {
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 20rpx;
}

.error-msg text {
  font-size: 24rpx;
  color: #ff4d4f;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.tips-text {
  text-align: center;
  padding: 4rpx 0 16rpx;
}

.tips-text text {
  font-size: 24rpx;
  color: #bbbbbb;
}

.switch-link {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.switch-link text {
  font-size: 26rpx;
  color: #1677ff;
}

.skip-link {
  text-align: center;
  padding: 8rpx 0;
}

.skip-link text {
  font-size: 24rpx;
  color: #cccccc;
}
