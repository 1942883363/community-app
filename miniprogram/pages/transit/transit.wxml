<view class="page">
  <view class="location-card card">
    <view class="location-header flex-between">
      <text class="location-title">📍 当前位置</text>
      <text class="text-secondary location-action" bindtap="onRefreshLocation">🔄 刷新</text>
    </view>
    <view wx:if="{{location.address}}" class="location-row">
      <text class="location-text">{{location.address}}</text>
    </view>
    <view wx:else class="location-row">
      <text class="location-text text-secondary">获取位置中...</text>
    </view>
  </view>

  <view class="line-search card">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="输入线路名称搜索..."
        value="{{lineKeyword}}"
        bindinput="onLineInput"
        bindconfirm="onSearchLine"
      />
    </view>
  </view>

  <view wx:if="{{lineList.length > 0}}" class="section">
    <text class="section-title">🚌 搜索结果</text>
    <view
      class="line-card card"
      wx:for="{{lineList}}"
      wx:key="id"
    >
      <text class="line-name">{{item.name}}</text>
      <view wx:if="{{item.stops && item.stops.length > 0}}" class="line-stops">
        <text wx:for="{{item.stops}}" wx:key="*this" wx:for-item="stop" class="line-stop">{{stop}}</text>
      </view>
      <text wx:if="{{item.start_time || item.end_time}}" class="text-secondary">运营时间: {{item.start_time}} ~ {{item.end_time}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">🚏 周边站点</text>
    <block wx:if="{{stations.length > 0}}">
      <view
        class="station-card card"
        wx:for="{{stations}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onStationTap"
      >
        <view class="flex-between">
          <view class="flex-row station-info">
            <text class="station-emoji">🚏</text>
            <view class="flex-column">
              <text class="station-name">{{item.name}}</text>
              <text wx:if="{{item.distance}}" class="text-secondary">{{item.distance}}m</text>
            </view>
          </view>
          <text class="text-primary">线路 ›</text>
        </view>
        <view wx:if="{{item.lines && item.lines.length > 0}}" class="station-lines">
          <text
            wx:for="{{item.lines}}"
            wx:key="*this"
            wx:for-item="line"
            class="line-tag"
          >{{line}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty-state">
      <text class="icon">🗺️</text>
      <text class="text">获取站点中...</text>
    </view>
  </view>
</view>
