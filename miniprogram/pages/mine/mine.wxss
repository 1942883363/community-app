.page {
  padding-bottom: 48rpx;
}

.user-header {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.25);
  padding: 0;
  margin: 0 0 20rpx 0;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  line-height: 1;
}

.avatar-wrap::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.edit-btn {
  margin-top: 12rpx;
  padding: 10rpx 36rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.register-btn {
  margin-top: 4rpx;
  padding: 10rpx 36rpx;
  background: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #1677ff;
  font-weight: 500;
}

.edit-area {
  width: 100%;
  max-width: 500rpx;
}

.edit-avatar-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.phone-input {
  width: 100%;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.phone-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.edit-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.cancel-btn {
  font-size: 24rpx !important;
}

.save-btn {
  font-size: 24rpx !important;
}

.record-tabs {
  margin: 0 24rpx 24rpx;
  padding: 8rpx;
  border-radius: 16rpx;
}

.tabs {
  justify-content: space-around;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #1677ff;
  color: #ffffff;
  font-weight: 500;
}

.tab-content {
  padding: 0 24rpx;
}

.list-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.list-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.more-section {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
}

.more-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.more-text {
  font-size: 28rpx;
  color: #333333;
}

.logout-section {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
}

.logout-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.logout-text {
  font-size: 28rpx;
  color: #ff4d4f;
}
