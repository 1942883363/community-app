.page {
  padding-bottom: 24rpx;
}

.search-bar {
  padding: 20rpx 24rpx;
  background: #ffffff;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  min-height: 40rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999999;
  padding: 4rpx 8rpx;
}

.tab-scroll {
  white-space: nowrap;
  background: #ffffff;
  padding: 16rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
}

.tab-item {
  display: inline-flex;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f5f5f5;
}

.tab-item.active {
  background: #1677ff;
  color: #ffffff;
}

.phone-card {
  margin: 16rpx 24rpx;
  padding: 24rpx;
}

.phone-info {
  flex: 1;
  min-width: 0;
}

.phone-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.phone-number {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.phone-remark {
  margin-top: 2rpx;
}

.call-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #e6f4ff;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.call-icon {
  font-size: 32rpx;
}

.call-text {
  font-size: 22rpx;
  color: #1677ff;
  margin-top: 4rpx;
}
