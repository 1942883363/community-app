.page {
  padding-bottom: 24rpx;
}

.banner-swiper {
  width: 100%;
  height: 340rpx;
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.banner-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.service-grid {
  display: flex;
  flex-wrap: wrap;
  background: #ffffff;
  padding: 24rpx 16rpx;
  margin-bottom: 24rpx;
}

.service-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.service-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.service-emoji {
  font-size: 40rpx;
}

.service-name {
  font-size: 24rpx;
  color: #333333;
}

.section {
  padding: 0 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.news-card {
  padding: 20rpx;
}

.news-card-body {
  align-items: flex-start;
}

.news-info {
  flex: 1;
  margin-right: 20rpx;
  min-width: 0;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.news-summary {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.news-meta {
  gap: 24rpx;
}

.news-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.news-cover-placeholder {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.news-cover-placeholder text {
  font-size: 48rpx;
}
