.page {
  padding-bottom: 24rpx;
}

.search-bar {
  padding: 20rpx 24rpx;
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  min-height: 40rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999999;
  padding: 4rpx 8rpx;
}

.tab-scroll {
  white-space: nowrap;
  background: #ffffff;
  padding: 16rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
}

.tab-item {
  display: inline-flex;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f5f5f5;
  transition: all 0.2s;
}

.tab-item.active {
  background: #1677ff;
  color: #ffffff;
}

.news-card {
  margin: 16rpx 24rpx;
  padding: 20rpx;
}

.news-card-body {
  align-items: flex-start;
}

.news-info {
  flex: 1;
  margin-right: 20rpx;
  min-width: 0;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.news-summary {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.news-meta {
  gap: 24rpx;
}

.news-cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.news-cover-placeholder {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.news-cover-placeholder text {
  font-size: 48rpx;
}
