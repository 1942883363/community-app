.detail-header {
  padding: 0;
  margin: 0 24rpx 16rpx;
}

.detail-cover {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx 16rpx 0 0;
}

.detail-cover-placeholder {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx 16rpx 0 0;
  background: linear-gradient(135deg, #1677ff, #52c41a);
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-cover-placeholder text {
  font-size: 80rpx;
}

.detail-header-info {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 0 0 16rpx 16rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.detail-meta-row {
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.meta-icon {
  font-size: 26rpx;
  width: 36rpx;
  text-align: center;
}

.meta-text {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

.detail-body {
  margin: 0 24rpx 160rpx;
}

.rich-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333333;
}

.register-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 24rpx;
  border-top: 2rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.register-info {
  text-align: center;
  margin-bottom: 12rpx;
}

.register-btn {
  width: 100%;
}

.register-btn.disabled {
  background: #cccccc;
}

.register-form-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.register-form {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.form-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-btn.cancel {
  background: #f5f5f5;
  color: #666666;
}

.form-btn.submit {
  background: #1677ff;
  color: #ffffff;
}
