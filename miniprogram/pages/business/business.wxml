<view class="page">
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索商家..."
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <text wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <scroll-view class="tab-scroll" scroll-x enable-flex>
    <view class="tab-item {{currentCategory === '' ? 'active' : ''}}" data-category="" bindtap="onCategoryTap">
      <text>全部</text>
    </view>
    <view
      class="tab-item {{currentCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      data-category="{{item.id}}"
      bindtap="onCategoryTap"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <block wx:if="{{businessList.length > 0}}">
    <view
      class="business-card card"
      wx:for="{{businessList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onBusinessTap"
    >
      <view class="business-body flex-row">
        <image
          wx:if="{{item.image}}"
          class="business-image"
          src="{{item.image}}"
          mode="aspectFill"
          lazy-load
        />
        <view wx:else class="business-image-placeholder">
          <text>🏪</text>
        </view>
        <view class="business-info flex-column">
          <text class="business-name">{{item.name}}</text>
          <text class="business-address text-ellipsis">📍 {{item.address}}</text>
          <view wx:if="{{item.phone}}" class="business-phone flex-row">
            <text>📞 {{item.phone}}</text>
          </view>
          <text wx:if="{{item.description}}" class="business-desc text-ellipsis-2">{{item.description}}</text>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{hasMore}}">
      <text>{{loadingMore ? '加载中...' : '上拉加载更多'}}</text>
    </view>
    <view class="loading-more" wx:else>
      <text>— 没有更多了 —</text>
    </view>
  </block>

  <view wx:else class="empty-state">
    <text class="icon">📭</text>
    <text class="text">暂无商家</text>
  </view>
</view>
