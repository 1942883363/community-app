.page {
  padding-bottom: 48rpx;
}

.user-header {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.user-id {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.record-tabs {
  margin: 0 24rpx 24rpx;
  padding: 8rpx;
  border-radius: 16rpx;
}

.tabs {
  justify-content: space-around;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #1677ff;
  color: #ffffff;
  font-weight: 500;
}

.tab-content {
  padding: 0 24rpx;
}

.list-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.list-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.more-section {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
}

.more-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.more-text {
  font-size: 28rpx;
  color: #333333;
}
