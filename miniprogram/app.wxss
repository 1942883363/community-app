page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.text-primary {
  color: #1677ff;
}

.text-secondary {
  color: #999999;
  font-size: 24rpx;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.btn-primary {
  background: #1677ff;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
}

.btn-primary:active {
  background: #0958d9;
}

.btn-outline {
  background: #ffffff;
  color: #1677ff;
  border: 2rpx solid #1677ff;
  border-radius: 12rpx;
  padding: 18rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-state .text {
  color: #999999;
  font-size: 28rpx;
}

.loading-more {
  text-align: center;
  padding: 24rpx;
  color: #999999;
  font-size: 24rpx;
}

.tag {
  display: inline-block;
  background: #e6f4ff;
  color: #1677ff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}
