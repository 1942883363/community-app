.swiper {
  width: 100%;
  height: 400rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #fa8c16, #ffc069);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-placeholder text {
  font-size: 100rpx;
}

.info-section {
  padding: 24rpx;
  background: #ffffff;
  margin-bottom: 16rpx;
}

.business-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.meta-item {
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.meta-text {
  font-size: 28rpx;
  color: #666666;
  flex: 1;
}

.call-tip {
  font-size: 22rpx;
  color: #1677ff;
}

.desc-section {
  margin: 0 24rpx 160rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-top: 2rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-btn {
  flex: 1;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  border: 2rpx solid #1677ff;
  background: #ffffff;
}

.action-btn-primary {
  background: #1677ff;
  border-color: #1677ff;
}

.action-btn-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.action-btn-text {
  font-size: 28rpx;
  color: #1677ff;
  font-weight: 500;
}

.action-btn-primary .action-btn-text {
  color: #ffffff;
}
