.search-bar {
  padding: 20rpx 24rpx;
  background: #ffffff;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  min-height: 40rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999999;
  padding: 4rpx 8rpx;
}

.tab-scroll {
  white-space: nowrap;
  background: #ffffff;
  padding: 16rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
}

.tab-item {
  display: inline-flex;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f5f5f5;
}

.tab-item.active {
  background: #1677ff;
  color: #ffffff;
}

.business-card {
  margin: 16rpx 24rpx;
  padding: 20rpx;
}

.business-body {
  align-items: flex-start;
}

.business-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.business-image-placeholder {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.business-image-placeholder text {
  font-size: 44rpx;
}

.business-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.business-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.business-address {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.business-phone {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.business-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  margin-top: 4rpx;
}
